  "privacyIntroTitle": "Privacy & Policy",
  "@privacyIntroTitle": { "description": "Section heading inside privacy policy page" },

  "privacyIntroBody": "UNIUN is built on transparency. Your data stays on your device. Below is everything you need to know — no legal jargon.",
  "@privacyIntroBody": { "description": "Intro paragraph on privacy policy page" },

  "privacyExpandPrivacy": "Privacy Policy",
  "@privacyExpandPrivacy": { "description": "Expandable section title — privacy policy" },

  "privacyExpandTerms": "Terms of Use",
  "@privacyExpandTerms": { "description": "Expandable section title — terms of use" },

  "privacyLastUpdated": "Last updated: June 2025",
  "@privacyLastUpdated": { "description": "Footer date on privacy policy page" },

  "privacyContactEmail": "privacy@uniun.app",
  "@privacyContactEmail": { "description": "Contact email shown on privacy policy page" },

  "privacyStoredLocallyTitle": "What We Store Locally",
  "@privacyStoredLocallyTitle": {},
  "privacyStoredLocallyBody": "UNIUN stores your notes, profile, saved items, channel messages, and settings directly on your device. This data is not sent to any server controlled by UNIUN.",
  "@privacyStoredLocallyBody": {},

  "privacySharedPubliclyTitle": "What Gets Shared Publicly",
  "@privacySharedPubliclyTitle": {},
  "privacySharedPubliclyBody": "When you publish a note or send a message in a public channel, that content is broadcast to Nostr relays. Nostr is an open public protocol — once published, your notes may be visible to anyone connected to those relays. UNIUN does not control third-party relays.",
  "@privacySharedPubliclyBody": {},

  "privacyIdentityKeysTitle": "Your Identity & Keys",
  "@privacyIdentityKeysTitle": {},
  "privacyIdentityKeysBody": "Your identity is a cryptographic key pair. Your public key is visible to others on the Nostr network. Your private key (nsec) is stored exclusively in your device's secure system keychain (iOS Keychain / Android Keystore). UNIUN never transmits your private key to any server.",
  "@privacyIdentityKeysBody": {},

  "privacyLocalAiTitle": "Local AI (Shiv)",
  "@privacyLocalAiTitle": {},
  "privacyLocalAiBody": "The Shiv AI assistant runs entirely on your device. It accesses only your locally saved notes. No note content is sent to any external AI service or API.",
  "@privacyLocalAiBody": {},

  "privacyMediaTitle": "Media & Blossom Servers",
  "@privacyMediaTitle": {},
  "privacyMediaBody": "If you attach images or media, they may be uploaded to a Blossom content server of your choice. UNIUN does not operate Blossom servers. Content uploaded there may be publicly accessible by design of the protocol.",
  "@privacyMediaBody": {},

  "privacyDmsTitle": "Direct Messages",
  "@privacyDmsTitle": {},
  "privacyDmsBody": "DMs are end-to-end encrypted using the Nostr NIP-17 standard. Only the intended recipient can read the message content. Message routing metadata may be visible to relays.",
  "@privacyDmsBody": {},

  "privacyControlTitle": "Your Control",
  "@privacyControlTitle": {},
  "privacyControlBody": "You can delete your local data at any time from Settings. Because Nostr is a public protocol, notes already published to relays cannot be retracted — this is an intentional property of the network, not a limitation of the app.",
  "@privacyControlBody": {},

  "privacyContactTitle": "Contact",
  "@privacyContactTitle": {},
  "privacyContactBody": "For privacy questions: privacy@uniun.app",
  "@privacyContactBody": {},

  "termsResponsibilityTitle": "Your Responsibility",
  "@termsResponsibilityTitle": {},
  "termsResponsibilityBody": "You are solely responsible for all content you publish on UNIUN. By using the app, you agree not to post content that is illegal, abusive, harassing, or violates others' rights.",
  "@termsResponsibilityBody": {},

  "termsNoAbuseTitle": "No Abuse or Spam",
  "@termsNoAbuseTitle": {},
  "termsNoAbuseBody": "Do not use UNIUN to spam, harass, impersonate others, or conduct automated activity that disrupts the Nostr network.",
  "@termsNoAbuseBody": {},

  "termsPrivateKeyTitle": "Keep Your Private Key Safe",
  "@termsPrivateKeyTitle": {},
  "termsPrivateKeyBody": "Your private key (nsec) is your identity and login. If you lose it, your account cannot be recovered — UNIUN has no way to reset or recover private keys. Back it up in a secure location.",
  "@termsPrivateKeyBody": {},

  "termsPublicContentTitle": "Public Content on Relays",
  "@termsPublicContentTitle": {},
  "termsPublicContentBody": "Notes and channel messages you publish are sent to Nostr relays and may be visible to anyone on the network. Do not share sensitive personal information in public notes.",
  "@termsPublicContentBody": {},

  "termsAppMayChangeTitle": "App May Change",
  "@termsAppMayChangeTitle": {},
  "termsAppMayChangeBody": "UNIUN is in active development. Features, relay behavior, and policies may change over time. We will communicate significant updates within the app.",
  "@termsAppMayChangeBody": {},

  "termsNoWarrantyTitle": "No Warranty",
  "@termsNoWarrantyTitle": {},
  "termsNoWarrantyBody": "UNIUN is provided as-is. We make no guarantees about relay uptime, third-party server availability, or persistence of content on external relays.",
  "@termsNoWarrantyBody": {},

